{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=16.17.0"
  },
  "scripts": {
    "predev": "node scripts/assert-no-tailwind-oxide.mjs",
    "dev": "node scripts/run-dev.mjs",
    "prebuild": "node scripts/assert-no-tailwind-oxide.mjs",
    "dev:vite": "node -r ./scripts/webcrypto-polyfill.cjs ./node_modules/vite/bin/vite.js --port=3000 --host=0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "build": "node -r ./scripts/webcrypto-polyfill.cjs ./node_modules/vite/bin/vite.js build",
    "start": "tsx server/index.ts",
    "preview": "node -r ./scripts/webcrypto-polyfill.cjs ./node_modules/vite/bin/vite.js preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "express": "^4.21.2",
    "dotenv": "^17.2.3",
    "motion": "^12.23.24"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "@types/express": "^4.17.21"
  }
}
