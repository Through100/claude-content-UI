# --- Frontend (Vite) ---
# Optional: absolute API origin when the UI is not served from the same host as the API.
# VITE_API_BASE_URL="https://seo-tools.internal.company"

# Dev only: where the Express API runs (Vite proxies /api here).
# VITE_DEV_API_ORIGIN="http://127.0.0.1:8787"

# Live terminal during runs uses SSE (/api/run/stream). Set to 0 to use one-shot /api/run only.
# VITE_RUN_STREAM=0

# Max wait in the browser for GET /api/usage (runs /usage then /cost) and GET /api/account (ms). Default 360000 (6m). For Usage, set well above ~2× CLAUDE_USAGE_TIMEOUT_MS.
# VITE_USAGE_FETCH_TIMEOUT_MS=360000

# --- Backend (Express + Claude Code) ---
# API listens here. `npm run dev:server` does NOT start Vite — UI dev server is port 3000 (`npm run dev` / `dev:vite`).
PORT=8787

# Log every SEO run's full stdout/stderr to this process terminal (default on). Set to 0 to disable.
# CLAUDE_LOG_RUNS=0

# Project directory where Claude Code runs (plugin workspace, CLAUDE.md, .claude/, etc.).
CLAUDE_WORKDIR=/path/to/your/project

# Claude Code executable. Use a full path if the API process PATH does not include the CLI (common in Docker).
# You may use ~/.local/bin/claude — the PTY proxy expands ~ before exec. Plain `claude` uses PATH.
# Example: CLAUDE_BIN=/root/.local/bin/claude
CLAUDE_BIN=claude

# Anthropic API key (Console) — Claude Code uses this for headless runs and usually avoids interactive `/login`.
# Same variable as the official CLI: https://docs.anthropic.com/en/docs/claude-code
# In a shell before `npm run start`: export ANTHROPIC_API_KEY="sk-ant-api03-…"
# Or set here (never commit a real key); Docker: copy/mount `.env` into the app dir or inject via orchestration.
# ANTHROPIC_API_KEY=

# Optional: keep CI=1 in the PTY child env (default: CI is unset so Claude treats the session as interactive).
# PTY_KEEP_CI=1

# If CLAUDE_BIN points at claude-code **cli.js**, the PTY proxy runs it with Node. Override when auto-detection fails:
# PTY_NODE=/home/you/.nvm/versions/node/v20.20.2/bin/node
# (CLAUDE_NODE is accepted as an alias.)
# PTY_PROXY_DEBUG=1 logs resolved child argv + cwd on the proxy stderr (visible in server logs / terminal UI).

# Long-running SEO commands (ms). Default 30 minutes. Must be >= 1000 (never 0 — that SIGTERMs Claude instantly).
# CLAUDE_TIMEOUT_MS=1800000

# Per-probe timeout for the Usage page (ms). Default 3 minutes. The server runs `claude "/usage"` then `claude "/cost"` sequentially, each under this outer cap — worst-case wall time is roughly 2× this value.
# CLAUDE_USAGE_TIMEOUT_MS=180000

# Inner `timeout` for `claude "/usage"` and `claude "/cost"` (e.g. 5s, 10s). Invalid values fall back to 5s.
# CLAUDE_USAGE_BASH_USAGE_TIMEOUT_SPEC=5s

# Inner `timeout` for Account Info `claude "/status"` (e.g. 4s). Uses the same `script` PTY toggles as Usage. Invalid values fall back to 4s.
# CLAUDE_ACCOUNT_STATUS_TIMEOUT_SPEC=4s

# Interactive xterm WebSocket (`/api/terminal/ws`) for a raw `claude` PTY in Account Info (staff type `/login` etc.). Set to 0 to disable (recommended on untrusted networks).
# CLAUDE_TERMINAL_WS=0

# Linux (default): wrap the inner command in `script -qec '…' /dev/null` so `claude` gets a PTY (avoids Unknown skill: usage/status when Node uses pipes). Set to disable:
# CLAUDE_USAGE_NO_SCRIPT_PTY=1
# Force the same `script` wrapper on non-Linux (may not work on all macOS `script` implementations):
# CLAUDE_USAGE_SCRIPT_PTY=1
#
# AlmaLinux 9 (and other RHEL-like) containers: install `util-linux` for `script`; bash + GNU `timeout` are standard. Put `claude` on PATH or set CLAUDE_BIN.

# Wrap **slash argv** fallback spawns (`/status`, `/stats`, etc., not default `/usage`) in bash. Use 1 for `bash -c` if PATH/nvm needs it.
# CLAUDE_USAGE_BASH_LC=1

# With BASH_LC=1, use login shell `bash -lc` instead of `bash -c` (loads profile/nvm; the API clears npm_config_prefix in the child env).
# CLAUDE_USAGE_BASH_LOGIN=1

# Add --bare to the headless `/usage` `-p` run. See Claude Code headless docs.
# CLAUDE_USAGE_BARE_PROBES=1

# Headless runs: the API passes --permission-mode bypassPermissions by default (non-root only) so WebFetch/MCP can run without a TTY.
# Claude Code refuses that mode when the process is root — run Node as a non-root user (e.g. USER node in Docker).
# CLAUDE_PERMISSION_MODE=bypassPermissions
# CLAUDE_DISABLE_AUTO_PERMISSION_MODE=1
#
# Optional: extra CLI args appended after -p (space-separated).
# CLAUDE_EXTRA_ARGS=

# On server start: run `claude --init-only` in CLAUDE_WORKDIR after version check.
# CLAUDE_RUN_INIT_ONLY=1

# Optional model override for Usage page Claude runs (`-p` probes).
# CLAUDE_USAGE_MODEL=sonnet

# Persisted run history (JSON array).
# HISTORY_PATH=data/history.json
# HISTORY_MAX_ITEMS=500

# Override model dropdown (JSON array of { id, label, description? }).
# CLAUDE_MODELS_JSON=[{"id":"sonnet","label":"Sonnet","description":"Latest"}]

# Legacy AI Studio / Gemini (not used by this internal wiring).
# GEMINI_API_KEY=
# APP_URL=
